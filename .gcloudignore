# Build context for `gcloud run deploy --source .`. The Dockerfile only needs
# pyproject.toml, uv.lock, README.md, and ./app — keep everything else out so
# the upload stays small.
.git/
.venv/
# Ship only the built SPA from frontend/dist (mounted as StaticFiles in
# fast_api_app.py). Keep node_modules and sources out of the build context.
frontend/node_modules/
frontend/src/
frontend/index.html
frontend/vite.config.ts
frontend/tsconfig*.json
frontend/tsconfig.tsbuildinfo
frontend/package*.json
scripts/
tests/
.adk/
.ruff_cache/
.pytest_cache/
__pycache__/
*.pyc
.gcloudignore
GEMINI.md
*.tfvars
.env
