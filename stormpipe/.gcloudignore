# Build context for `gcloud run deploy --source .`. The Dockerfile only needs
# pyproject.toml, uv.lock, README.md, and ./app — keep everything else out so
# the upload stays small.
.git/
.venv/
frontend/
scripts/
tests/
.adk/
.ruff_cache/
.pytest_cache/
__pycache__/
*.pyc
.gcloudignore
GEMINI.md
*.tfvars
.env
